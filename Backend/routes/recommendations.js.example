      {
        "_id": "...",
        "name": "Paris City Tour",
        "tags": "europe culture museums",
        ...other tour fields
      },
      ...
    ],
    "method": "collaborative",
    "count": 3
  }
  
  2. GET /api/recommendations (No recommendations)
  ✅ 200 OK
  {
    "tours": [],
    "method": "none"
  }
  
  3. POST /api/recommendations/train
  ✅ 200 OK
  {
    "status": "success",
    "message": "Models trained successfully",
    "models_ready": true
  }
  
  4. GET /api/recommendations/health
  ✅ 200 OK
  {
    "status": "healthy",
    "models_ready": true
  }
  
  5. Error: AI Service Offline
  ❌ 503 Service Unavailable
  {
    "message": "AI Service is offline",
    "error": "Cannot connect to recommendation service"
  }
  
  6. Error: Not Authenticated
  ❌ 401 Unauthorized
  {
    "message": "User not authenticated"
  }
*/
