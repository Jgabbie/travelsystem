{
    "routes": [
        {
            "route": "/static/*",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "route": "/images/*",
            "headers": {
                "Cache-Control": "public, max-age=604800, stale-while-revalidate=86400"
            }
        }
    ],
    "globalHeaders": {
        "Cache-Control": "no-cache"
    },
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/static/*",
            "/images/*",
            "/*.{css,js,png,jpg,jpeg,gif,svg,webp,ico,json,woff,woff2}"
        ]
    }
}